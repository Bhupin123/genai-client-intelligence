# ─────────────────────────────────────────────────────────────────────────────
# GenAI Client Intelligence Platform — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq (required) ──────────────────────────────────────────────────────────
GROQ_API_KEY=groq_api_key_here

# ── LLM behaviour (optional — defaults shown) ─────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_MAX_VALIDATION_RETRIES=3
LLM_MAX_API_RETRIES=3
LLM_REQUEST_TIMEOUT=120.0

# ── API server (optional — defaults shown) ────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_ENV=production        # production | staging | development

# ── Logging (optional — defaults shown) ───────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true               # true = structured JSON logs, false = human-readable

# ── Rate limiting (optional — defaults shown) ─────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60